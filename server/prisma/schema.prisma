// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password_hash String
  role          String
  created_at    DateTime @default(now())

  // Relations
  studentProfile StudentProfile?
  companyProfile CompanyProfile?
  supportTickets SupportTicket[]

  @@map("users")
}

model StudentProfile {
  user_id    Int     @id
  full_name  String
  university String?
  bio        String?
  phone      String?
  linkedin_url String?
  github_url   String?
  twitter_url  String?
  website_url  String?
  major               String?
  graduation_year     Int?
  availability_status String @default("available")
  categories_of_interest String?

  user User @relation(fields: [user_id], references: [id])

  // Relations
  skills          StudentSkill[]
  submissions     Submission[]
  recommendations Recommendation[]
  savedTasks      SavedTask[]

  @@map("student_profiles")
}

model CompanyProfile {
  user_id      Int     @id
  company_name String
  description  String?
  website_url  String?
  industry     String?
  location     String?
  logo_url     String?

  user User @relation(fields: [user_id], references: [id])

  // Relations
  tasks                  Task[]
  recommendationsWritten Recommendation[]

  @@map("company_profiles")
}

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Relations
  students StudentSkill[]
  tasks    TaskSkill[]

  @@map("skills")
}

model StudentSkill {
  student_user_id Int
  skill_id        Int
  category        String @default("General")
  level           Int    @default(3)

  student StudentProfile @relation(fields: [student_user_id], references: [user_id])
  skill   Skill          @relation(fields: [skill_id], references: [id])

  @@id([student_user_id, skill_id])
  @@map("student_skills")
}

model Task {
  id                   Int       @id @default(autoincrement())
  company_user_id      Int
  title                String
  description          String?
  category             String?
  subcategory          String?
  reward_type          String?
  reward_amount        String?
  budget               String?
  currency             String?
  internship_duration  String?
  internship_department String?
  internship_is_paid   String?
  certificate_name     String?
  certificate_issuer   String?
  positions            Int?
  experience_level     String?
  preferred_major      String?
  work_type            String?
  detail_title         String?
  detail_body          String?
  created_at           DateTime  @default(now())
  status               String?
  deadline             DateTime?
  location             String?
  employment_type      String?

  company CompanyProfile @relation(fields: [company_user_id], references: [user_id])

  // Relations
  requiredSkills TaskSkill[]
  submissions    Submission[]
  savedTasks     SavedTask[]

  @@map("tasks")
}

model TaskSkill {
  task_id           Int
  skill_id          Int
  level             Int     @default(5)
  is_required       Boolean @default(true)
  years_of_experience Int?

  task  Task  @relation(fields: [task_id], references: [id])
  skill Skill @relation(fields: [skill_id], references: [id])

  @@id([task_id, skill_id])
  @@map("task_skills")
}

model Submission {
  id                 Int      @id @default(autoincrement())
  task_id            Int
  student_user_id    Int
  status             String?
  submission_content String?
  submitted_at       DateTime @default(now())
  proposed_budget         String?
  estimated_delivery_days Int?
  ai_match_score          Float?

  task    Task           @relation(fields: [task_id], references: [id])
  student StudentProfile @relation(fields: [student_user_id], references: [user_id])

  // Relations
  review Review?

  @@map("submissions")
}

model Review {
  submission_id Int     @id
  rating        Int?
  feedback      String?

  submission Submission @relation(fields: [submission_id], references: [id])

  // Relations
  awardedBadges AwardedBadge[]

  @@map("reviews")
}

model Badge {
  id       Int     @id @default(autoincrement())
  name     String
  icon_url String?

  // Relations
  awarded AwardedBadge[]

  @@map("badges")
}

model AwardedBadge {
  review_id Int
  badge_id  Int

  review Review @relation(fields: [review_id], references: [submission_id])
  badge  Badge  @relation(fields: [badge_id], references: [id])

  @@id([review_id, badge_id])
  @@map("awarded_badges")
}

model Recommendation {
  id              Int      @id @default(autoincrement())
  company_user_id Int
  student_user_id Int
  content         String
  created_at      DateTime @default(now())

  company CompanyProfile @relation(fields: [company_user_id], references: [user_id])
  student StudentProfile @relation(fields: [student_user_id], references: [user_id])

  @@map("recommendations")
}

model SupportTicket {
  id         Int      @id @default(autoincrement())
  user_id    Int
  subject    String
  message    String
  status     String   @default("open")
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("support_tickets")
}

model SavedTask {
  student_user_id Int
  task_id         Int
  saved_at        DateTime @default(now())

  student StudentProfile @relation(fields: [student_user_id], references: [user_id])
  task    Task           @relation(fields: [task_id], references: [id])

  @@id([student_user_id, task_id])
  @@map("saved_tasks")
}
